# backend/.env.example — Environment Variables Template
# ======================================================
# Copy this file to .env and fill in your actual values before running locally.
# DO NOT commit .env to git — it contains secrets.
#
# In production (AWS Lambda), these values are injected automatically
# via the SAM template (sam-template.yaml) — no .env file is needed there.




# AWS Region
AWS_REGION=us-east-1

# Cognito
COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# DynamoDB Table names
DYNAMODB_USERS_TABLE=tribunet-users
DYNAMODB_MATCHES_TABLE=tribunet-matches
DYNAMODB_STADIUMS_TABLE=tribunet-stadiums
DYNAMODB_FAVORITES_TABLE=tribunet-favorites
DYNAMODB_TEAMS_TABLE=tribunet-teams
DYNAMODB_LEAGUES_TABLE=tribunet-leagues

# Frontend URL (for CORS)
FRONTEND_URL=https://xxxxxxxxxxxxxxxxxx.cloudfront.net
